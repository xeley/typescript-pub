{
  "name": "shield-rule-engine",
  "private": true,
  "version": "0.0.0",
  "description": "Shield Rule Engine — multi-tenant real-time fraud rule evaluator.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" run build && pnpm --filter @shield/shield-eval run build",
    "demo": "pnpm build && pnpm --filter @shield/shield-demo demo",
    "eval:dev": "pnpm --filter @shield/shield-eval dev",
    "eval:start": "pnpm --filter @shield/shield-eval start",
    "admin:dev": "pnpm --filter @shield/shield-admin dev",
    "admin:build": "pnpm --filter @shield/shield-admin build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.7.5",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@10.33.0"
}
